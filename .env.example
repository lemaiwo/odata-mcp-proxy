# =============================================================================
# CPI Admin MCP Server - Environment Configuration
# =============================================================================
# Destination names are now configured in src/config/api-config.json alongside
# each API's pathPrefix and entitySets. No destination name env var is needed.

# --- Optional ---

# Transport mode: "http" (for BTP deployment) or "stdio" (for Claude Desktop)
# MCP_TRANSPORT=http

# HTTP server port (only used when MCP_TRANSPORT=http)
# PORT=4004

# Logging level: error, warn, info, debug
# LOG_LEVEL=info

# HTTP request timeout in milliseconds
# REQUEST_TIMEOUT=60000

# Comma-separated list of API categories to enable (default: all)
# Options: integration-content, message-processing-logs, message-stores,
#          log-files, partner-directory, security-content
# ENABLED_API_CATEGORIES=all

# API config file to load (relative to src/config/ or absolute path)
# API_CONFIG_FILE=api-config.json   (default: api-config.json, also: btp-admin-api-config.json)

# --- Local development (no BTP / no VCAP_SERVICES) ---
#
# When VCAP_SERVICES is not present, credentials are read from env vars.
# The prefix is derived from the destination name in api-config.json:
# uppercase the name and replace non-alphanumeric characters with underscores.
#
# Example: destination "CPI_DESTINATION" → prefix "CPI_DESTINATION"
#
# CPI_DESTINATION_BASE_URL=https://your-tenant.it-cpi018.cfapps.eu10.hana.ondemand.com
# CPI_DESTINATION_TOKEN_URL=https://your-subdomain.authentication.eu10.hana.ondemand.com/oauth/token
# CPI_DESTINATION_CLIENT_ID=your_client_id
# CPI_DESTINATION_CLIENT_SECRET=your_client_secret

# --- API Keys for Task Master (development only) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
