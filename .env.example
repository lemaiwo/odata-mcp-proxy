# =============================================================================
# CPI Admin MCP Server - Environment Configuration
# =============================================================================

# --- Required ---

# BTP Destination name pointing to your Cloud Integration tenant
SAP_DESTINATION_NAME=your_ci_destination_name

# --- Optional ---

# Transport mode: "http" (for BTP deployment) or "stdio" (for Claude Desktop)
# MCP_TRANSPORT=http

# HTTP server port (only used when MCP_TRANSPORT=http)
# PORT=4004

# Logging level: error, warn, info, debug
# LOG_LEVEL=info

# HTTP request timeout in milliseconds
# REQUEST_TIMEOUT=60000

# Comma-separated list of API categories to enable (default: all)
# Options: integration-content, message-processing-logs, message-stores,
#          log-files, partner-directory, security-content
# ENABLED_API_CATEGORIES=all

# --- API Keys for Task Master (development only) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
