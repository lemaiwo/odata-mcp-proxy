{
  "name": "odata-mcp-proxy",
  "version": "1.0.0",
  "description": "Config-driven MCP proxy that exposes OData and REST APIs as MCP tools",
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.readdirSync('src/config').filter(f=>f.endsWith('.json')).forEach(f=>fs.copyFileSync('src/config/'+f,'dist/config/'+f))\"",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "start:stdio": "MCP_TRANSPORT=stdio node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector",
    "inspect:http": "npx @modelcontextprotocol/inspector --cli http://localhost:4004/mcp",
    "build:btp": "mbt build",
    "deploy:btp": "cf deploy mta_archives/odata-mcp-proxy_1.0.0.mtar"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.1",
    "@sap-cloud-sdk/connectivity": "^4.0.0",
    "@sap-cloud-sdk/http-client": "^4.0.0",
    "@sap/xsenv": "^4.0.0",
    "@sap/xssec": "^3.6.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "winston": "^3.17.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "task-master-ai": "^0.43.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
