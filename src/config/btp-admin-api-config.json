{
  "server": {
    "name": "btp-admin-mcp-server",
    "version": "1.0.0",
    "description": "MCP server for SAP BTP Core Services administration REST APIs"
  },
  "apis": [
    {
      "name": "cis-accounts",
      "destination": "BTP_ACCOUNTS_SERVICE",
      "pathPrefix": "/accounts/v1",
      "csrfProtected": false,
      "entitySets": [
        {
          "entitySet": "GlobalAccount",
          "urlPath": "global-account",
          "description": "BTP global account details",
          "category": "account-management",
          "keys": [],
          "operations": { "list": true, "get": false, "create": false, "update": false, "delete": false }
        },
        {
          "entitySet": "Subaccounts",
          "urlPath": "subaccounts",
          "description": "BTP subaccounts under the global account",
          "category": "account-management",
          "keys": [{ "name": "subaccountGUID", "type": "string" }],
          "operations": { "list": true, "get": true, "create": true, "update": true, "delete": true }
        },
        {
          "entitySet": "Directories",
          "urlPath": "directories",
          "description": "BTP directories used to group subaccounts",
          "category": "account-management",
          "keys": [{ "name": "directoryGUID", "type": "string" }],
          "operations": { "list": true, "get": true, "create": true, "update": true, "delete": true }
        }
      ]
    },
    {
      "name": "cis-entitlements",
      "destination": "BTP_ENTITLEMENTS_SERVICE",
      "pathPrefix": "/entitlements/v1",
      "csrfProtected": false,
      "entitySets": [
        {
          "entitySet": "Assignments",
          "urlPath": "assignments",
          "description": "service plan entitlement assignments for subaccounts and directories",
          "category": "entitlements",
          "keys": [],
          "operations": { "list": true, "get": false, "create": false, "update": true, "delete": false }
        },
        {
          "entitySet": "AllowedDataCenters",
          "urlPath": "globalAccountAllowedDataCenters",
          "description": "data centers available for the global account",
          "category": "entitlements",
          "keys": [],
          "operations": { "list": true, "get": false, "create": false, "update": false, "delete": false }
        }
      ]
    },
    {
      "name": "cis-provisioning",
      "destination": "BTP_PROVISIONING_SERVICE",
      "pathPrefix": "/provisioning/v1",
      "csrfProtected": false,
      "entitySets": [
        {
          "entitySet": "EnvironmentInstances",
          "urlPath": "environmentInstances",
          "description": "runtime environment instances (e.g. Cloud Foundry orgs) in a subaccount",
          "category": "entitlements",
          "keys": [{ "name": "environmentInstanceID", "type": "string" }],
          "operations": { "list": true, "get": true, "create": true, "update": false, "delete": true }
        },
        {
          "entitySet": "AvailableEnvironments",
          "urlPath": "availableEnvironments",
          "description": "runtime environment types available for provisioning",
          "category": "entitlements",
          "keys": [],
          "operations": { "list": true, "get": false, "create": false, "update": false, "delete": false }
        }
      ]
    },
    {
      "name": "service-manager",
      "destination": "BTP_SERVICE_MANAGER",
      "pathPrefix": "/v1",
      "csrfProtected": false,
      "entitySets": [
        {
          "entitySet": "ServiceBrokers",
          "urlPath": "service_brokers",
          "description": "registered service brokers in the subaccount",
          "category": "service-management",
          "keys": [{ "name": "brokerID", "type": "string" }],
          "operations": { "list": true, "get": true, "create": true, "update": true, "delete": true }
        },
        {
          "entitySet": "ServiceInstances",
          "urlPath": "service_instances",
          "description": "service instances created from service plans",
          "category": "service-management",
          "keys": [{ "name": "instanceID", "type": "string" }],
          "operations": { "list": true, "get": true, "create": true, "update": true, "delete": true }
        },
        {
          "entitySet": "ServiceBindings",
          "urlPath": "service_bindings",
          "description": "service bindings that provide credentials for service instances",
          "category": "service-management",
          "keys": [{ "name": "bindingID", "type": "string" }],
          "operations": { "list": true, "get": true, "create": true, "update": false, "delete": true }
        },
        {
          "entitySet": "ServicePlans",
          "urlPath": "service_plans",
          "description": "service plans offered by registered brokers",
          "category": "service-management",
          "keys": [{ "name": "planID", "type": "string" }],
          "operations": { "list": true, "get": true, "create": false, "update": false, "delete": false }
        },
        {
          "entitySet": "ServiceOfferings",
          "urlPath": "service_offerings",
          "description": "service offerings (catalogued services) from registered brokers",
          "category": "service-management",
          "keys": [{ "name": "offeringID", "type": "string" }],
          "operations": { "list": true, "get": true, "create": false, "update": false, "delete": false }
        }
      ]
    },
    {
      "name": "destination-service",
      "destination": "BTP_DESTINATION_SERVICE",
      "pathPrefix": "/destination-configuration/v1",
      "csrfProtected": false,
      "entitySets": [
        {
          "entitySet": "SubaccountDestinations",
          "urlPath": "subaccountDestinations",
          "description": "destinations configured at the subaccount level",
          "category": "destination-management",
          "keys": [{ "name": "Name", "type": "string" }],
          "operations": { "list": true, "get": true, "create": true, "update": true, "delete": true }
        },
        {
          "entitySet": "InstanceDestinations",
          "urlPath": "instanceDestinations",
          "description": "destinations configured at the service instance level",
          "category": "destination-management",
          "keys": [{ "name": "Name", "type": "string" }],
          "operations": { "list": true, "get": true, "create": true, "update": true, "delete": true }
        }
      ]
    }
  ]
}
