{
  "server": {
    "name": "btp-admin-mcp-server",
    "version": "1.0.0",
    "description": "MCP server for SAP BTP Core Services administration REST APIs"
  },
  "apis": [
    {
      "name": "cis-accounts",
      "destination": "BTP_ACCOUNTS_SERVICE",
      "pathPrefix": "/accounts/v1",
      "csrfProtected": false,
      "entitySets": [
        {
          "entitySet": "GlobalAccount",
          "urlPath": "global-account",
          "description": "BTP global account details",
          "category": "account-management",
          "keys": [],
          "operations": { "list": true, "get": false, "create": false, "update": false, "delete": false }
        },
        {
          "entitySet": "Subaccounts",
          "urlPath": "subaccounts",
          "description": "BTP subaccounts under the global account",
          "category": "account-management",
          "keys": [{ "name": "subaccountGUID", "type": "string" }],
          "operations": { "list": true, "get": true, "create": true, "update": true, "delete": true }
        },
        {
          "entitySet": "Directories",
          "urlPath": "directories",
          "description": "BTP directories used to group subaccounts",
          "category": "account-management",
          "keys": [{ "name": "directoryGUID", "type": "string" }],
          "operations": { "list": true, "get": true, "create": true, "update": true, "delete": true }
        }
      ]
    }
  ]
}
